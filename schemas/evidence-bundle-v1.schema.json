{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proof-layer.dev/schemas/evidence-bundle-v1.schema.json",
  "title": "Evidence Bundle v1",
  "description": "Deterministic evidence bundle for session transcripts and provenance attestations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "session",
    "turns",
    "integrity",
    "signature",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+\\.[0-9]+$",
      "description": "Semantic schema version for v1.x.y bundles."
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "session": {
      "$ref": "#/$defs/sessionMetadata"
    },
    "turns": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/turn"
      },
      "description": "Ordered turn list; order is semantically significant and must be preserved."
    },
    "integrity": {
      "$ref": "#/$defs/integrity"
    },
    "signature": {
      "$ref": "#/$defs/signature"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "extensions": {
      "type": "object",
      "description": "Forward-compatible extension namespace for producer-specific fields.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "sessionMetadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "session_id",
        "started_at",
        "ended_at",
        "participants",
        "context"
      ],
      "properties": {
        "session_id": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "ended_at": {
          "type": "string",
          "format": "date-time"
        },
        "participants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/participant"
          }
        },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "environment",
            "region"
          ],
          "properties": {
            "environment": {
              "type": "string",
              "minLength": 1
            },
            "region": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "participant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "system",
            "user",
            "assistant",
            "tool"
          ]
        }
      }
    },
    "turn": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "turn_index",
        "role",
        "content_hash",
        "turn_hash"
      ],
      "properties": {
        "turn_index": {
          "type": "integer",
          "minimum": 0
        },
        "role": {
          "type": "string",
          "enum": [
            "system",
            "user",
            "assistant",
            "tool"
          ]
        },
        "content_hash": {
          "$ref": "#/$defs/sha256Digest"
        },
        "prev_turn_hash": {
          "anyOf": [
            {
              "$ref": "#/$defs/sha256Digest"
            },
            {
              "type": "null"
            }
          ]
        },
        "turn_hash": {
          "$ref": "#/$defs/sha256Digest"
        }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonicalization",
        "hash_algorithm",
        "bundle_hash",
        "turn_order_hash"
      ],
      "properties": {
        "canonicalization": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "spec",
            "version",
            "normalization"
          ],
          "properties": {
            "spec": {
              "const": "RFC8785-JCS"
            },
            "version": {
              "type": "string",
              "minLength": 1
            },
            "normalization": {
              "const": "UTF-8"
            }
          }
        },
        "hash_algorithm": {
          "const": "SHA-256"
        },
        "bundle_hash": {
          "$ref": "#/$defs/sha256Digest"
        },
        "turn_order_hash": {
          "$ref": "#/$defs/sha256Digest"
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "key_id",
        "signed_at",
        "signature_value"
      ],
      "properties": {
        "algorithm": {
          "type": "string",
          "enum": [
            "Ed25519",
            "ES256",
            "RS256"
          ]
        },
        "key_id": {
          "type": "string",
          "minLength": 1
        },
        "signed_at": {
          "type": "string",
          "format": "date-time"
        },
        "signature_value": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "producer",
        "captured_at",
        "source_refs"
      ],
      "properties": {
        "producer": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "version"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "version": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "uri",
              "digest"
            ],
            "properties": {
              "type": {
                "type": "string",
                "minLength": 1
              },
              "uri": {
                "type": "string",
                "minLength": 1
              },
              "digest": {
                "$ref": "#/$defs/sha256Digest"
              }
            }
          }
        }
      }
    }
  }
}
