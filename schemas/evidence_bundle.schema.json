{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proof-layer.dev/schemas/evidence_bundle.schema.json",
  "title": "Evidence Bundle",
  "description": "Signed v1.0 bundle emitted by proofctl and the proof service.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_version",
    "bundle_id",
    "created_at",
    "actor",
    "subject",
    "items",
    "artefacts",
    "policy",
    "integrity"
  ],
  "properties": {
    "bundle_version": {
      "const": "1.0"
    },
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "actor": {
      "$ref": "./capture_event.schema.json#/properties/actor"
    },
    "subject": {
      "$ref": "./capture_event.schema.json#/properties/subject"
    },
    "context": {
      "$ref": "./capture_event.schema.json#/properties/context"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./evidence_item.schema.json"
      }
    },
    "artefacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "digest",
          "size",
          "content_type"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          },
          "size": {
            "type": "integer",
            "minimum": 0
          },
          "content_type": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "policy": {
      "$ref": "./capture_event.schema.json#/properties/policy"
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "canonicalization",
        "hash",
        "header_digest",
        "bundle_root_algorithm",
        "bundle_root",
        "signature"
      ],
      "properties": {
        "canonicalization": {
          "const": "RFC8785-JCS"
        },
        "hash": {
          "const": "SHA-256"
        },
        "header_digest": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "bundle_root_algorithm": {
          "type": "string",
          "enum": [
            "pl-merkle-sha256-v1",
            "pl-merkle-sha256-v2",
            "pl-merkle-sha256-v3",
            "pl-merkle-sha256-v4"
          ],
          "description": "New bundles use pl-merkle-sha256-v4 with path-level item digests for nested selective disclosure; pl-merkle-sha256-v3, pl-merkle-sha256-v2, and pl-merkle-sha256-v1 remain valid for compatibility."
        },
        "bundle_root": {
          "type": "string",
          "pattern": "^sha256:[0-9a-f]{64}$"
        },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "format",
            "alg",
            "kid",
            "value"
          ],
          "properties": {
            "format": {
              "const": "JWS"
            },
            "alg": {
              "const": "EdDSA"
            },
            "kid": {
              "type": "string",
              "minLength": 1
            },
            "value": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "timestamp": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "token_base64"
      ],
      "properties": {
        "kind": {
          "const": "rfc3161"
        },
        "provider": {
          "type": "string"
        },
        "token_base64": {
          "type": "string",
          "minLength": 1,
          "description": "Base64 of DER-encoded RFC 3161 CMS SignedData."
        }
      }
    },
    "receipt": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "body"
          ],
          "properties": {
            "kind": {
              "const": "rekor"
            },
            "provider": {
              "type": "string"
            },
            "body": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "log_url",
                "entry_uuid",
                "log_entry"
              ],
              "properties": {
                "log_url": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Base URL of the Rekor instance that integrated the receipt."
                },
                "entry_uuid": {
                  "type": "string",
                  "pattern": "^([0-9a-fA-F]{64}|[0-9a-fA-F]{80})$"
                },
                "log_entry": {
                  "type": "object",
                  "minProperties": 1,
                  "description": "Raw Rekor LogEntry response keyed by entry UUID."
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "kind",
            "body"
          ],
          "properties": {
            "kind": {
              "const": "scitt"
            },
            "provider": {
              "type": "string"
            },
            "body": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "service_url",
                "entry_id",
                "service_id",
                "registered_at",
                "statement_b64",
                "statement_hash",
                "receipt_b64"
              ],
              "properties": {
                "service_url": {
                  "type": "string",
                  "minLength": 1,
                  "description": "SCITT receipt service submission endpoint that returned the receipt."
                },
                "entry_id": {
                  "type": "string",
                  "minLength": 1
                },
                "service_id": {
                  "type": "string",
                  "pattern": "^[0-9a-fA-F]{64}$"
                },
                "registered_at": {
                  "type": "string",
                  "format": "date-time"
                },
                "statement_b64": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Base64 of the canonical JSON statement submitted to the SCITT-style service."
                },
                "statement_hash": {
                  "type": "string",
                  "pattern": "^sha256:[0-9a-fA-F]{64}$"
                },
                "receipt_b64": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Base64 of the transparency-service signature over the canonical receipt payload."
                }
              }
            }
          }
        }
      ]
    }
  }
}
