{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://proof-layer.dev/schemas/evidence_pack.schema.json",
  "title": "Evidence Pack",
  "description": "Envelope for future Annex-aligned pack assembly. Pack generation is not implemented yet.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_id",
    "pack_type",
    "generated_at",
    "bundle_ids"
  ],
  "properties": {
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "pack_type": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "bundle_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "notes": {
      "type": "string"
    },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "content_type"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "content_type": {
            "type": "string",
            "minLength": 1
          },
          "digest": {
            "type": "string",
            "pattern": "^sha256:[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
