{
  "name": "@proof-layer/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for Proof Layer tamper-evident AI evidence capture and verification.",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "native",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./proof-layer": {
      "types": "./dist/proof_layer.d.ts",
      "import": "./dist/proof_layer.js"
    },
    "./local-client": {
      "types": "./dist/local_client.d.ts",
      "import": "./dist/local_client.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js"
    },
    "./evidence": {
      "types": "./dist/evidence.d.ts",
      "import": "./dist/evidence.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./providers/openai": {
      "types": "./dist/providers/openai.d.ts",
      "import": "./dist/providers/openai.js"
    },
    "./providers/anthropic": {
      "types": "./dist/providers/anthropic.d.ts",
      "import": "./dist/providers/anthropic.js"
    },
    "./providers/generic": {
      "types": "./dist/providers/generic.d.ts",
      "import": "./dist/providers/generic.js"
    },
    "./providers/vercel-ai": {
      "types": "./dist/providers/vercel_ai.d.ts",
      "import": "./dist/providers/vercel_ai.js"
    },
    "./otel": {
      "types": "./dist/otel/index.d.ts",
      "import": "./dist/otel/index.js"
    },
    "./errors": {
      "types": "./dist/utils/errors.d.ts",
      "import": "./dist/utils/errors.js"
    },
    "./chat": {
      "types": "./dist/chat.d.ts",
      "import": "./dist/chat.js"
    },
    "./advanced": {
      "types": "./dist/advanced.d.ts",
      "import": "./dist/advanced.js"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/proof-layer/proof-layer-sdk.git",
    "directory": "sdks/typescript"
  },
  "license": "MIT",
  "scripts": {
    "build:native": "node ./scripts/build-native.mjs",
    "build": "npm run build:native && tsc -p tsconfig.json",
    "pack:smoke": "node ./scripts/pack-smoke.mjs",
    "prepack": "npm run build",
    "pretest": "npm run build",
    "test": "node --test"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  }
}
